{
  "name": "oppivelvollisuus-api-gateway",
  "version": "0.0.1",
  "description": "API gateway for oppivelvollisuus",
  "type": "module",
  "private": true,
  "license": "LGPL-2.1-or-later",
  "scripts": {
    "clean": "rm -rf ./build ./dist",
    "type-check": "tsc",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "yarn lint --fix",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest",
    "dev": "concurrently --prefix '[{name}]' --names 'tsc,node' 'tsc --preserveWatchOutput --watch' 'NODE_ENV=local node --watch-preserve-output --watch src/index.ts'",
    "test-ci": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "prepack": "exit 1"
  },
  "dependencies": {
    "@node-saml/node-saml": "5.1.0",
    "axios": "1.18.1",
    "connect-redis": "9.0.0",
    "cookie-parser": "1.4.7",
    "date-fns": "4.4.0",
    "dd-trace": "5.114.0",
    "express": "5.2.1",
    "express-http-proxy": "2.1.2",
    "express-session": "1.19.0",
    "fast-xml-parser": "5.10.1",
    "helmet": "8.3.0",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "make-error-cause": "2.3.0",
    "nocache": "4.0.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "pump": "3.0.4",
    "query-string": "9.4.1",
    "redis": "5.12.1",
    "split2": "4.2.0",
    "through2": "5.0.5",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.4.1",
    "@types/cookie-parser": "1.4.10",
    "@types/express-http-proxy": "1.6.7",
    "@types/express-session": "1.19.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/lodash": "4.17.24",
    "@types/ms": "2.1.0",
    "@types/node": "25.9.5",
    "@types/node-forge": "1.3.14",
    "@types/pump": "1.1.3",
    "@types/readable-stream": "4.0.24",
    "@types/split2": "4.2.3",
    "@types/tough-cookie": "4.0.5",
    "@types/xml2js": "0.4.14",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "concurrently": "9.2.4",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "nock": "14.0.16",
    "node-forge": "1.4.0",
    "nodemon": "3.1.14",
    "prettier": "3.9.5",
    "tough-cookie": "6.0.2",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "xml-crypto": "6.1.2",
    "xml2js": "0.6.2"
  },
  "jest-junit": {
    "outputDirectory": "./build/test-reports/",
    "outputName": "jest-junit.xml"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  },
  "resolutions": {
    "@types/ms": "2.1.0",
    "shell-quote": "1.10.0"
  },
  "engines": {
    "node": ">= 22.18.0"
  },
  "packageManager": "yarn@4.17.1"
}
